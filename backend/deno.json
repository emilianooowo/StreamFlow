{
  "lock": false,
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-run --allow-env src/server.ts",
    "dev": "deno run --allow-net --allow-read --allow-run --allow-env --watch src/server.ts",
    "test": "deno test --allow-net --allow-read --allow-run --allow-env",
    "worker": "deno run --allow-net --allow-read --allow-run --allow-env src/workers/video-processor.ts"
  },
  "imports": {
    "@hono/node-server": "npm:@hono/node-server@^1.13.0",
    "hono": "jsr:@hono/hono@^4.6.0",
    "@hono/hono": "jsr:@hono/hono@^4.6.0",
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/fs": "jsr:@std/fs@^1.0.4",
    "postgres": "npm:postgres@^3.4.8",
    "minio": "npm:minio@^7.1.3",
    "jsonwebtoken": "npm:jsonwebtoken@^9.0.2",
    "google-auth-library": "npm:google-auth-library@^10.1.0",
    "bcryptjs": "npm:bcryptjs@^2.4.3",
    "@types/bcryptjs": "npm:@types/bcryptjs@^2.4.6"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "test": {
    "include": ["tests/"]
  }
}
